# Smart Learning Agent runtime configuration
# Copy this file to .env when you want to enable remote model providers.

# Change this value before public deployment. It is used to sign JWT login tokens.
APP_AUTH_JWT_SECRET=replace_with_a_long_random_secret
APP_AUTH_TOKEN_TTL_HOURS=12

# Keep mock for offline demo. Use deepseek to enable DeepSeek/OpenAI-compatible chat API.
AI_PROVIDER=mock
AI_BASE_URL=https://api.deepseek.com
AI_CHAT_PATH=/chat/completions
AI_API_KEY=replace_with_your_api_key
AI_MODEL=deepseek-v4-flash
AI_THINKING_ENABLED=false
AI_REASONING_EFFORT=medium

# DeepSeek chat models are suitable for generation, but usually do not provide embeddings.
# Keep mock for low-cost demo, or configure an OpenAI-compatible embedding provider.
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=
EMBEDDING_PATH=/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Must match the real embedding vector dimension. Mock embedding uses 64.
APP_VECTOR_DIMENSION=64
APP_VECTOR_TOP_K=6
